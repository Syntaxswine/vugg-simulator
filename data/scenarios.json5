      "events": [
        { "step":   5, "type": "tn457_mn_ba_pulse", "name": "Pulse  1", "description": "Ba+Mn pulse 1 of 50 (barite gate first cleared here)" },
        { "step":   7, "type": "tn457_mn_ba_pulse", "name": "Pulse  2", "description": "Ba+Mn pulse 2 of 50" },
        { "step":   9, "type": "tn457_mn_ba_pulse", "name": "Pulse  3", "description": "Ba+Mn pulse 3 of 50" },
        { "step":  11, "type": "tn457_mn_ba_pulse", "name": "Pulse  4", "description": "Ba+Mn pulse 4 of 50" },
        { "step":  13, "type": "tn457_mn_ba_pulse", "name": "Pulse  5", "description": "Ba+Mn pulse 5 of 50" },
        { "step":  15, "type": "tn457_mn_ba_pulse", "name": "Pulse  6", "description": "Ba+Mn pulse 6 of 50" },
        { "step":  17, "type": "tn457_mn_ba_pulse", "name": "Pulse  7", "description": "Ba+Mn pulse 7 of 50" },
        { "step":  19, "type": "tn457_mn_ba_pulse", "name": "Pulse  8", "description": "Ba+Mn pulse 8 of 50" },
        { "step":  21, "type": "tn457_mn_ba_pulse", "name": "Pulse  9", "description": "Ba+Mn pulse 9 of 50" },
        { "step":  23, "type": "tn457_mn_ba_pulse", "name": "Pulse 10", "description": "Ba+Mn pulse 10 of 50" },
