agent-api/game*-grooves/

# Python bytecode — regenerated on every run
__pycache__/
*.pyc

# pytest — local cache, regenerated per run
.pytest_cache/

# Editor / tooling local config
# .claude/* ignores top-level files (launch.json, settings.local.json,
# agent state) without blocking recursion into subdirectories — required
# so the negation patterns below can re-include the project-level skills
# subtree (.claude/skills/ is committed: it's workflow documentation the
# whole team / future agents can use).
.claude/*
!.claude/skills/

# TypeScript build output + npm artifacts
node_modules/
dist/
*.tsbuildinfo

# Cold-CI verdict stamp (tools/cold-ci.mjs) — per-machine, per-run state;
# committing it would churn every run and vouch for trees it never saw
.ci-stamp.json

# strip-archive-diff.mjs --html scratch output (ad-hoc visual overlays);
# the COMMITTED record is archive/strips/v<N>/, not these throwaway diffs
.strip-diffs/

# review-claim-card.mjs --all scratch output (regenerable from archive/strips +
# scenarios); the COMMITTED record is proposals/DATA-HOSTILE-REVIEW-*.json
.review-cards/
